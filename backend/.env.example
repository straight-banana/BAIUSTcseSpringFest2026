# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (Aiven PostgreSQL) ──────────────────────────
# Format: postgresql://user:password@host:port/db?sslmode=require
DATABASE_URL="postgres://avnadmin:<redacted>@pg-37514dc-demo-practice.k.aivencloud.com:13961/defaultdb?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Your React frontend URL (Vercel)
FRONTEND_URL=http://127.0.0.1:5500/

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
