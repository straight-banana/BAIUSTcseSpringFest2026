# Local Postgres started via `docker-compose up -d` at the repo root.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon?schema=public

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Generate real secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI provider config — see contracts/ai-contract.md
CUSTOM_AI_API_URL=http://localhost:11434/api/generate
CUSTOM_AI_API_KEY=
OPENSOURCE_AI_API_URL=https://api-inference.huggingface.co/models/your-model
OPENSOURCE_AI_API_KEY=
